// Job Application Tracker — Prisma schema
// Run `npx prisma migrate dev --name <name>` to create + apply migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String        @map("password_hash")
  createdAt    DateTime      @default(now()) @map("created_at")

  applications Application[]
  resumes      Resume[]

  @@map("users")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  website   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  applications Application[]
  contacts     Contact[]

  @@index([name])
  @@map("companies")
}

model Application {
  id                String            @id @default(uuid())
  userId            String            @map("user_id")
  companyId         String            @map("company_id")
  role              String
  status            ApplicationStatus @default(APPLIED)
  appliedAt         DateTime          @default(now()) @map("applied_at")
  lastFollowedUpAt  DateTime?         @map("last_followed_up_at")
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([appliedAt])
  @@map("applications")
}

model Contact {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String
  email     String?
  role      String?
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("contacts")
}

model Resume {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  s3Key      String   @map("s3_key")
  filename   String
  sizeBytes  Int      @map("size_bytes")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resumes")
}

// Audit log of domain events (also published to Kafka). Useful for replay/debugging.
model Event {
  id         String   @id @default(uuid())
  type       String
  payload    Json
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([type, occurredAt])
  @@map("events")
}
